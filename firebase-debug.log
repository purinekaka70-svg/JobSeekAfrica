[debug] [2026-03-16T13:50:34.756Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/jobseekafrica/rulesets {"name":"projects/jobseekafrica/rulesets/74b6a699-b0c1-4bb9-a2f0-255624f039d6","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return request.auth != null &&\n        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&\n        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.enabled != false;\n    }\n\n    function isEmailUser() {\n      return request.auth != null &&\n        request.auth.token.email != null;\n    }\n\n    // Jobs are public read-only (written by Cloud Functions).\n    match /jobs/{jobId} {\n      allow read: if true;\n      allow create: if isAdmin() || (isEmailUser() && request.resource.data.approved == false);\n      allow update, delete: if isAdmin();\n    }\n\n    // CVs: allow creation and read. Admins can update/delete.\n    match /cvs/{cvId} {\n      allow read: if true;\n      allow create: if isSignedIn();\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n\n    // QR codes: public create/read.\n    match /qrcodes/{qrId} {\n      allow read: if true;\n      allow create: if isSignedIn();\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n\n    // Cover letters: public create/read.\n    match /letters/{letterId} {\n      allow read: if true;\n      allow create: if isSignedIn();\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n\n    // Portfolios: public create/read.\n    match /portfolios/{portfolioId} {\n      allow read: if true;\n      allow create: if isSignedIn();\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n\n    // Payments: allow create only (no public reads for privacy).\n    match /payments/{paymentId} {\n      allow create: if isSignedIn();\n      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n\n    // Admin allowlist (managed in Firebase Console).\n    match /admins/{adminId} {\n      allow read: if request.auth != null && request.auth.uid == adminId;\n      allow create, update, delete: if false;\n    }\n\n    // User profiles.\n    match /users/{userId} {\n      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);\n      allow create, update: if request.auth != null && request.auth.uid == userId;\n      allow delete: if isAdmin();\n    }\n\n    // Default deny.\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-16T13:50:34.275167Z","metadata":{"services":["cloud.firestore"]}}
