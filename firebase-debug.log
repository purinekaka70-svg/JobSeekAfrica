[debug] [2026-03-16T12:59:57.387Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/jobseekafrica/rulesets {"name":"projects/jobseekafrica/rulesets/4a68457b-400d-4607-a46f-bd143450b492","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      // Treat any signed-in email/password user as admin.\n      // Anonymous users are not admins.\n      return request.auth != null &&\n        request.auth.token.email != null;\n    }\n\n    // Jobs are public read-only (written by Cloud Functions).\n    match /jobs/{jobId} {\n      allow read: if true;\n      allow create, update, delete: if isAdmin();\n    }\n\n    // CVs: allow creation and read. Allow only approval updates (no deletes).\n    match /cvs/{cvId} {\n      allow read: if true;\n      allow create: if isSignedIn();\n      allow update: if isAdmin() &&\n        request.resource.data.diff(resource.data).changedKeys()\n          .hasOnly([\"downloadApproved\", \"updatedAt\"]);\n      allow delete: if false;\n    }\n\n    // QR codes: public create/read.\n    match /qrcodes/{qrId} {\n      allow read: if true;\n      allow create: if isSignedIn();\n      allow update, delete: if false;\n    }\n\n    // Cover letters: public create/read.\n    match /letters/{letterId} {\n      allow read: if true;\n      allow create: if isSignedIn();\n      allow update, delete: if false;\n    }\n\n    // Portfolios: public create/read.\n    match /portfolios/{portfolioId} {\n      allow read: if true;\n      allow create: if isSignedIn();\n      allow update, delete: if false;\n    }\n\n    // Payments: allow create only (no public reads for privacy).\n    match /payments/{paymentId} {\n      allow create: if isSignedIn();\n      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);\n      allow update: if isAdmin();\n      allow delete: if false;\n    }\n\n    // Default deny.\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-16T12:59:56.881871Z","metadata":{"services":["cloud.firestore"]}}
