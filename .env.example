# Firebase configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Careerjet API (Kenya jobs)
CAREERJET_API_KEY=your_careerjet_api_key
# Optional: fixed-IP proxy endpoint (e.g. Fly). Must be absolute URL.
CAREERJET_PROXY_ENDPOINT=https://your-fly-app.fly.dev/careerjet
# Optional: locale (default en_KE)
CAREERJET_LOCALE=en_KE
# Optional: set if IP lookup fails in the browser
CAREERJET_USER_IP=your_public_ip
# Optional: allow direct browser calls to Careerjet (not recommended)
FETCH_CAREERJET_DIRECT=false
# Optional: user agent for Careerjet sync
CAREERJET_USER_AGENT=JobSeekAfrica/1.0
# Optional: how many pages to sync in the Cloud Function
CAREERJET_PAGES=6
# Optional: results per page (max 50 for Careerjet)
CAREERJET_PAGE_SIZE=50
# Optional: Firestore collection used by the sync
JOBS_COLLECTION=jobs

# Careerjet cache (Firestore) - requires FIREBASE_SERVICE_ACCOUNT to be set
# Optional: disable cache read/write entirely (default true)
CAREERJET_CACHE_ENABLED=true
# Cache TTL in minutes (default 360 = 6 hours)
CAREERJET_CACHE_TTL_MINUTES=360
# Optional: Firestore collection name for cache
CAREERJET_CACHE_COLLECTION=careerjet_cache
# Optional: serve stale cache when Careerjet fails (default true)
CAREERJET_ALLOW_STALE_CACHE=true
# Optional: include error details in API response (default false)
CAREERJET_DEBUG=false
# Optional: store Careerjet jobs into Firestore "jobs" collection (default true if FIREBASE_SERVICE_ACCOUNT is set)
CAREERJET_STORE_JOBS=true
# Optional: Firestore collection name for stored jobs (default jobs)
CAREERJET_STORE_COLLECTION=jobs
# Optional: mark stored jobs as approved (default true)
CAREERJET_STORE_APPROVED=true
# Optional: default keywords used when q is empty (comma separated)
CAREERJET_DEFAULT_KEYWORDS=security,guard,assistant,intern,driver,customer service,sales,admin,data,technician
# Optional: limit how many default keywords to query (default 8)
CAREERJET_DEFAULT_KEYWORD_LIMIT=8
# Optional: cap on total jobs returned across keywords (default 300, max 500)
CAREERJET_MAX_JOBS=300

# Job listings API (serverless proxy)
USE_SERVER_API=true
JOBS_API_ENDPOINT=/api/jobs
JOBS_PAGES=6
JOBS_RESULTS_PER_PAGE=50

# M-Pesa Daraja (STK Push prompt)
# Set these in Vercel (do NOT expose in the browser).
MPESA_OAUTH_URL=your_oauth_url_from_daraja
MPESA_STK_PUSH_URL=your_stk_push_url_from_daraja
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORT_CODE=your_till_or_paybill_number
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_TRANSACTION_TYPE=your_transaction_type
MPESA_CALLBACK_URL=https://your-vercel-domain/api/mpesa-callback
MPESA_AMOUNT=100
MPESA_ACCOUNT_REFERENCE=JobSeekAfrica
MPESA_TRANSACTION_DESC=JobSeekAfrica payment
# Optional: override the frontend endpoint
MPESA_API_ENDPOINT=/api/mpesa-stk

# Optional: Firestore Admin SDK for serverless payment logging
# Provide the full service account JSON or base64-encoded JSON.
FIREBASE_SERVICE_ACCOUNT=your_service_account_json_or_base64

# Admin login
ADMIN_EMAIL=admin@jobseekafrica.com
ADMIN_PASSWORD=change_me

# Optional: require admin approval before CV PDF download
REQUIRE_CV_APPROVAL=false
